# Copy to .env and fill in. Never commit your real .env.

# --- Roster source ---
# Where your roster comes from: espn (default) | sleeper | manual.
# Override per command with --source / --league / --team.
FF_ROSTER_SOURCE=espn

# --- ESPN (default roster source) ---
# League id is in your league URL (.../leagues/<ID>).
ESPN_LEAGUE_ID=
# PUBLIC leagues: set your team id (.../teams/<ID>) so the app knows which is yours.
ESPN_TEAM_ID=
# PRIVATE leagues: paste the two cookies from your logged-in browser
# (DevTools > Application > Cookies). With SWID, the app auto-detects your team.
ESPN_S2=
ESPN_SWID=

# --- Manual roster (when FF_ROSTER_SOURCE=manual or --source manual) ---
# Path to a hand-edited CSV with headers: name,team,position
FF_MANUAL_ROSTER=manual_roster.csv

# --- Sleeper (alternate roster source) ---
# Your Sleeper username. The app resolves this to your user id.
SLEEPER_USERNAME=your_sleeper_username
# Optional: pin a specific league. If unset, the app lists your leagues and
# uses the first NFL league for the current season.
SLEEPER_LEAGUE_ID=

# --- Vegas (The Odds API) ---
# Free tier key from https://the-odds-api.com/  (~500 requests/month).
# If unset, the app still runs on ECR alone and marks Vegas as unavailable.
ODDS_API_KEY=

# --- FantasyPros ECR ---
# Optional API key. If unset (or if the API call fails), the app falls back to
# scraping the public weekly rankings page.
FANTASYPROS_API_KEY=

# --- Tuning (all optional; sensible defaults baked in) ---
# Scoring format: ppr | half | std
FF_SCORING=ppr
# Blend weights (named for the signals). Defaults: ecr=0.65, vegas=0.20, injury=0.15.
# Negative or all-zero weights are rejected and the defaults are used instead.
FF_WEIGHT_ECR=0.65
FF_WEIGHT_VEGAS=0.20
FF_WEIGHT_INJURY=0.15
# Final scores within this 0-100 gap are flagged "too close to call".
FF_CLOSE_CALL_THRESHOLD=5.0
# Injury signal uses the free public Sleeper player data (no key). Set to 0/false
# to turn it off and blend on ECR + Vegas alone.
FF_INJURY=1
# Before Week 1 there is no live ECR/Vegas data, so runs are filled with bundled
# SAMPLE data (clearly labeled with a preseason warning). Set to 0/false to show
# the warning with empty slots instead.
FF_PRESEASON_FILL=1

# --- Distribution (optional) ---
# Discord incoming webhook (Server Settings > Integrations > Webhooks). If set,
# `ffstartsit notify` (and the weekly Action) push the lineup + alerts to it.
DISCORD_WEBHOOK_URL=
# Public dashboard URL the notification links to. In the weekly Action this is
# filled automatically from the GitHub Pages deploy; set it for local `notify`.
FF_DASHBOARD_URL=
# Repo web URL (https://github.com/<owner>/<repo>). Used by the Discord embed to
# link to the GitHub issues where the / commands work. In the weekly Action this
# is derived automatically from GITHUB_REPOSITORY; set it for local `notify`.
FF_REPO_URL=
